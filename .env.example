# Copy this file to .env and fill in all values before running docker compose.

# ── Database ─────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=change-me-user

# ── WordPress (must match the DB credentials above) ───────────────────────────
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-me-user

# Public URL of your site (used to set WP_HOME and WP_SITEURL)
SITE_URL=https://your-domain.example

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Zero Trust dashboard → Networks → Tunnels → <your tunnel> → Overview → Token
TUNNEL_TOKEN=paste-your-cloudflared-tunnel-token-here
